<VirtualHost *:80>
    ServerName admin.noxpanama.com
    DocumentRoot /home/noxpa/public_html/admin/public

    <Directory /home/noxpa/public_html/admin/public>
        Options -Indexes
        AllowOverride All
        Require all granted
    </Directory>

    <Directory /home/noxpa/public_html/admin/app>
        Require all denied
    </Directory>

    <Directory /home/noxpa/public_html/admin/config>
        Require all denied
    </Directory>

    <Directory /home/noxpa/public_html/admin/db>
        Require all denied
    </Directory>

    <Directory /home/noxpa/public_html/admin/scripts>
        Require all denied
    </Directory>

    ErrorLog /var/log/httpd/nox-admin-error.log
    CustomLog /var/log/httpd/nox-admin-access.log combined

    RewriteEngine On
    RewriteCond %{SERVER_NAME} =admin.noxpanama.com
    RewriteRule ^ https://%{SERVER_NAME}%{REQUEST_URI} [END,NE,R=permanent]
</VirtualHost>
